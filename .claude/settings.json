{
  "permissions": {
    "allow": [
      "Bash(pdm add *)",
      "Bash(pdm install*)",
      "Bash(pdm run pytest*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ls*)",
      "Bash(pwd*)",
      "Bash(git push*)",
      "Bash(gh pr *)",
      "Bash(mkdir *)",
      "Bash(pdm run:*)",
      "Bash(find:*)",
      "Bash(docker *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset*)",
      "Bash(git clean*)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lsp-reminder.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/concise-response.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pdm run format; pdm run lint"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "duronext-jig": {
      "source": {
        "source": "github",
        "repo": "duronext/jig"
      }
    }
  }
}
