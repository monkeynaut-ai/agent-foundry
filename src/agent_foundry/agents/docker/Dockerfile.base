# Agent Container Protocol — Base Claude Code Worker Image
#
# Provides: Claude Code CLI, websockets, non-root user, gosu, entrypoint.
# Products layer on top to add CLAUDE.md, skills, plugins, etc.
#
# The entrypoint runs as root to enforce filesystem lockdown (WORKSPACE_HIDDEN_DIRS,
# WORKSPACE_READONLY_DIRS), then drops to the claude user via gosu before launching
# the agent. This follows the same pattern as the official PostgreSQL and
# Redis Docker images.
#
# Build:
#   docker build -t agent-worker:latest -f src/agent_foundry/agents/docker/Dockerfile.base .

FROM python:3.13

# Install system dependencies (including gosu for root-to-user drop)
RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl jq bash-completion gosu \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user (uid 1000) for agent execution via gosu
RUN groupadd -g 1000 claude \
    && useradd -m -u 1000 -g claude -s /bin/bash claude

# Switch to claude for build-time installations
USER claude
ENV HOME=/home/claude
WORKDIR /home/claude

# Install Claude Code native binary
RUN curl -fsSL https://claude.ai/install.sh | bash
ENV PATH="/home/claude/.local/bin:${PATH}"

# Verify installation
RUN claude --version

# Install Python dependencies for the headless adapter
RUN pip install --no-cache-dir websockets pydantic

# Install Pyright language server for LSP code intelligence.
# The first invocation downloads a bundled Node.js — do it at build time
# so the container starts with Pyright ready immediately.
RUN pip install --no-cache-dir pyright \
    && pyright --version

# Switch back to root for entrypoint setup
USER root

# Shell configuration — bash completion, git prompt, useful aliases
COPY --chown=claude:claude src/agent_foundry/agents/docker/.bashrc /home/claude/.bashrc

# Copy base configuration and entrypoint
COPY --chown=claude:claude src/agent_foundry/agents/docker/settings.json /home/claude/.claude/settings.json
COPY --chown=claude:claude src/agent_foundry/agents/docker/claude.json /home/claude/.claude.json
COPY src/agent_foundry/agents/docker/lockdown.sh /home/claude/lockdown.sh
COPY src/agent_foundry/agents/docker/entrypoint.sh /home/claude/entrypoint.sh
RUN chmod +x /home/claude/entrypoint.sh /home/claude/lockdown.sh

# Copy the ACP package so the adapter's imports resolve
COPY --chown=claude:claude src/agent_foundry/__init__.py /home/claude/lib/agent_foundry/__init__.py
COPY --chown=claude:claude src/agent_foundry/agents/__init__.py /home/claude/lib/agent_foundry/agents/__init__.py
COPY --chown=claude:claude src/agent_foundry/agents/adapter.py /home/claude/lib/agent_foundry/agents/adapter.py
COPY --chown=claude:claude src/agent_foundry/agents/protocol.py /home/claude/lib/agent_foundry/agents/protocol.py
COPY --chown=claude:claude src/agent_foundry/agents/errors.py /home/claude/lib/agent_foundry/agents/errors.py
ENV PYTHONPATH="/home/claude/lib"

# Copy the Claude Code adapter
COPY --chown=claude:claude src/agent_foundry/agents/adapters/claude_code.py /home/claude/adapter.py

# Generic agent brief and skills shipped with the base image. Products
# may append role-specific instruction files at runtime via
# write_file_to_container.
COPY --chown=claude:claude src/agent_foundry/agents/docker/CLAUDE.md /home/claude/.claude/CLAUDE.md
COPY --chown=claude:claude src/agent_foundry/agents/docker/skills/lessons-learned/SKILL.md /home/claude/.claude/skills/lessons-learned/SKILL.md

WORKDIR /workspace

# HEALTHCHECK — the entrypoint touches /tmp/.container-ready after all
# setup (auth, lockdown, role-instructions append, LSP plugin install,
# product-init hook) completes. Host code polls the container's health
# status to know when the container is ready to receive `docker exec`
# calls. `--start-period=60s` gives plugin install and product-init
# room to finish over slow networks without being counted as unhealthy.
HEALTHCHECK --interval=1s --timeout=3s --start-period=60s --retries=3 \
  CMD test -f /tmp/.container-ready || exit 1

ENTRYPOINT ["/home/claude/entrypoint.sh"]
