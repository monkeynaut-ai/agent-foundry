# Base Claude Code Worker Image
#
# Provides: Claude Code CLI, non-root user, gosu, entrypoint, generic
# agent brief (CLAUDE.md), lessons-learned skill.
#
# This image is language-agnostic: it has no Python, Node, or other
# language toolchains baked in. Per-language dev images (e.g.
# Dockerfile.foundry-dev) layer on top and add their own toolchains
# and LSP plugins via /etc/claude-code/managed-settings.json.
#
# Products layer on top to append role-specific CLAUDE-*.md files at
# runtime via write_file_to_container.
#
# The entrypoint runs as root to enforce filesystem lockdown
# (WORKSPACE_HIDDEN_DIRS, WORKSPACE_READONLY_DIRS), then drops to the
# claude user via gosu before the host invokes `claude` via docker exec.
#
# Build:
#   docker build -t agent-worker:latest -f src/agent_foundry/agents/docker/Dockerfile.base .

FROM debian:stable-slim

# Install system dependencies (including gosu for root-to-user drop, gh for PR creation).
# debian:stable-slim does not ship curl or ca-certificates, so install them up front.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
         | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
         > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends git jq bash-completion gosu gh \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user (uid 1000) for agent execution via gosu
RUN groupadd -g 1000 claude \
    && useradd -m -u 1000 -g claude -s /bin/bash claude

# Switch to claude for build-time installations
USER claude
ENV HOME=/home/claude
WORKDIR /home/claude

# Install Claude Code native binary
RUN curl -fsSL https://claude.ai/install.sh | bash
ENV PATH="/home/claude/.local/bin:${PATH}"

# Verify installation
RUN claude --version

# Switch back to root for entrypoint setup
USER root

# Shell configuration — bash completion, git prompt, useful aliases
COPY --chown=claude:claude src/agent_foundry/agents/docker/.bashrc /home/claude/.bashrc

# Copy base configuration and entrypoint
COPY --chown=claude:claude src/agent_foundry/agents/docker/settings.json /home/claude/.claude/settings.json
COPY --chown=claude:claude src/agent_foundry/agents/docker/claude.json /home/claude/.claude.json
COPY src/agent_foundry/agents/docker/lockdown.sh /home/claude/lockdown.sh
COPY src/agent_foundry/agents/docker/entrypoint.sh /home/claude/entrypoint.sh
RUN chmod +x /home/claude/entrypoint.sh /home/claude/lockdown.sh

# Generic agent brief and skills shipped with the base image. Products
# may append role-specific instruction files at runtime via
# write_file_to_container.
COPY --chown=claude:claude src/agent_foundry/agents/docker/CLAUDE.md /home/claude/.claude/CLAUDE.md
COPY --chown=claude:claude src/agent_foundry/agents/docker/skills/lessons-learned/SKILL.md /home/claude/.claude/skills/lessons-learned/SKILL.md

WORKDIR /workspace

# HEALTHCHECK — the entrypoint touches /tmp/.container-ready after all
# setup (auth, lockdown, role-instructions append, LSP plugin install)
# completes. Host code polls the container's health status to know when
# the container is ready to receive `docker exec` calls.
# `--start-period=60s` gives plugin install room to finish over slow
# networks without being counted as unhealthy.
HEALTHCHECK --interval=1s --timeout=3s --start-period=60s --retries=3 \
  CMD test -f /tmp/.container-ready || exit 1

ENTRYPOINT ["/home/claude/entrypoint.sh"]
