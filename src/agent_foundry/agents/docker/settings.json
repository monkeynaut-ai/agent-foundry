{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": ["Bash", "Read", "Edit", "Write", "Glob", "Grep", "Skill(lessons-learned)"],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Read(./secrets/**)"]
  },
  "sandbox": {
    "enabled": false
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_TMPDIR": "/tmp",
    "ENABLE_LSP_TOOL": "1"
  }
}
