{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": ["Bash", "Read", "Edit", "Write", "Glob", "Grep"],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Read(./secrets/**)"]
  },
  "sandbox": {
    "enabled": true,
    "enableWeakerNestedSandbox": true
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_TMPDIR": "/tmp",
    "ENABLE_LSP_TOOL": "1"
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'LSP CHECK: Is this symbol navigation (finding references, definitions, types, call chains, implementations)? If so, use LSP findReferences/goToDefinition/hover/incomingCalls/outgoingCalls/workspaceSymbol instead.' >&2"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'LSP CHECK: Are you searching for a class, function, or symbol by name? If so, use LSP workspaceSymbol instead.' >&2"
          }
        ]
      }
    ]
  }
}
